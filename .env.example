# ============================================================
# PrepTrack — Environment Variables Example
# Is file ko git mein commit karo (koi real key nahi hai isme)
# Naya developer is file ko copy karke .env.local banaye
# ============================================================

# Supabase (frontend-safe)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Sentry (frontend-safe)
VITE_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX

# Web Push VAPID public key (frontend-safe)
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# App URL
APP_URL=http://localhost:5173

# ============================================================
# NEECHE WALI KEYS SIRF SUPABASE EDGE FUNCTIONS SECRETS MEIN
# Junior developer ko in keys ki zaroorat NAHI hai
# ============================================================

# SUPABASE_SERVICE_ROLE_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL_GEMINI=google/gemini-pro-1.5
# OPENROUTER_MODEL_CHATGPT=openai/gpt-4o
# RESEND_API_KEY=
# EMAIL_FROM=PrepTrack <noreply@preptrack.app>
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:owner@preptrack.app
